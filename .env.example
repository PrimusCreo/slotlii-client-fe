# API
# Leave blank in local dev to use the Vite proxy at `/api` -> http://localhost:3000.
# In prod, set the full origin including the `/api` prefix, e.g. https://api.slotlii.com/api
VITE_API_BASE_URL=

# Meta / Facebook App — Embedded Signup
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_CONFIG_ID=
VITE_META_GRAPH_API_VERSION=v25.0
